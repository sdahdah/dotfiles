# Base16 Default Dark
# Author: Chris Kempson (http://chriskempson.com)

set default-bg                  "#000000"
set default-fg                  "#2e3436"

set statusbar-fg                "#babdb6"
set statusbar-bg                "#2e3436"

set inputbar-bg                 "#000000"
set inputbar-fg                 "#ffffff"

set notification-bg             "#000000"
set notification-fg             "#ffffff"

set notification-error-bg       "#000000"
set notification-error-fg       "#cc0000"

set notification-warning-bg     "#000000"
set notification-warning-fg     "#cc0000"

set highlight-color             "#fce94f"
set highlight-active-color      "#3465a4"

set completion-bg               "#2e3436"
set completion-fg               "#3465a4"

set completion-highlight-fg     "#ffffff"
set completion-highlight-bg     "#3465a4"

set recolor-lightcolor          "#000000"
set recolor-darkcolor           "#babdb6"

# Settings

set recolor                     "false"
set recolor-keephue             "false"

set window-title-basename       true
set selection-clipboard         clipboard
